{
  "name": "hosted-text-embeddings",
  "displayName": "Hosted Text Embeddings",
  "version": "0.0.38",
  "description": "Text embeddings via a Dataloop-hosted OpenAI-compatible service",
  "scope": "public",
  "attributes": {
    "Provider": "Dataloop",
    "Deployed By": "Dataloop",
    "Category": "Model",
    "NLP": "Embeddings",
    "Media Type": [
      "Text"
    ]
  },
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/openai-model-adapters.git",
    "gitTag": "0.0.38"
  },
  "components": {
    "computeConfigs": [
      {
        "name": "hosted-text-embeddings-deploy",
        "runtime": {
          "podType": "regular-xs",
          "concurrency": 1,
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 100
          },
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/openai-model-adapters:0.0.14"
        }
      }
    ],
    "modules": [
      {
        "name": "hosted-text-embeddings-module",
        "entryPoint": "adapters/hosted_text_embeddings/hosted_text_embeddings.py",
        "className": "HostedTextEmbeddings",
        "computeConfig": "hosted-text-embeddings-deploy",
        "description": "Hosted Text Embeddings Module",
        "initInputs": [
          {
            "type": "Model",
            "name": "model_entity"
          }
        ],
        "functions": [
          {
            "name": "embed_items",
            "input": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The input items for embeddings."
              }
            ],
            "output": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The same input items for embeddings."
              },
              {
                "type": "Json",
                "name": "json",
                "description": "Embeddings of items."
              }
            ],
            "displayName": "Embed Items",
            "displayIcon": "icon-dl-dell",
            "description": "The inference function of the model."
          },
          {
            "name": "embed_dataset",
            "input": [
              {
                "type": "Dataset",
                "name": "dataset",
                "description": "The input dataset of the items required for prediction."
              },
              {
                "type": "Json",
                "name": "filters",
                "description": "The DQL in json format to get all the items required for prediction."
              }
            ],
            "output": [],
            "displayName": "Embed Dataset",
            "displayIcon": "icon-dl-dell",
            "description": "Inference function of the model on a dataset."
          }
        ]
      }
    ],
    "models": [
      {
        "name": "hosted-text-embeddings",
        "moduleName": "hosted-text-embeddings-module",
        "scope": "project",
        "status": "pre-trained",
        "inputType": "text",
        "configuration": {
          "model_name": "",
          "app_id": ""
        },
        "description": "Text embeddings via Dataloop-hosted service"
      }
    ]
  }
}
