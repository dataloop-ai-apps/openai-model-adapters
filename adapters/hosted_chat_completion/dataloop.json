{
  "name": "hosted-chat-completion",
  "version": "0.0.36",
  "attributes": {
    "Provider": "Dataloop",
    "Category": "Model",
    "NLP": "Conversational",
    "Gen AI": "LMM",
    "Media Type": [
      "Text",
      "Image"
    ],
    "Deployed By": "Dataloop"
  },
  "displayName": "Hosted Chat Completion",
  "description": "Chat completion via a Dataloop-hosted OpenAI-compatible service",
  "scope": "public",
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/openai-model-adapters.git",
    "gitTag": "0.0.36"
  },
  "components": {
    "computeConfigs": [
      {
        "name": "hosted-chat-completion-deploy",
        "runtime": {
          "podType": "regular-xs",
          "concurrency": 10,
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 100
          },
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/openai-model-adapters:0.0.14"
        }
      }
    ],
    "modules": [
      {
        "name": "hosted-chat-completion-module",
        "entryPoint": "adapters/hosted_chat_completion/hosted_chat_completion.py",
        "className": "HostedChatCompletion",
        "computeConfig": "hosted-chat-completion-deploy",
        "description": "Hosted Chat Completion Module",
        "initInputs": [
          {
            "type": "Model",
            "name": "model_entity"
          }
        ],
        "functions": [
          {
            "name": "evaluate_model",
            "input": [
              {
                "type": "Model",
                "name": "model",
                "description": "Dataloop Model Entity"
              },
              {
                "type": "Dataset",
                "name": "dataset",
                "description": "Dataloop Dataset Entity"
              },
              {
                "type": "Json",
                "name": "filters",
                "description": "Dataloop Filter DQL"
              }
            ],
            "output": [
              {
                "type": "Model",
                "name": "model",
                "description": "Dataloop Model Entity"
              },
              {
                "type": "Dataset",
                "name": "dataset",
                "description": "Dataloop Dataset Entity"
              }
            ],
            "displayName": "Evaluate a Model",
            "displayIcon": "icon-dl-dell",
            "description": "Function to evaluate hosted chat completion model performance"
          },
          {
            "name": "predict_items",
            "input": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "List of items to run inference on"
              }
            ],
            "output": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The same input images for prediction."
              },
              {
                "type": "Annotation[]",
                "name": "annotations",
                "description": "The predicted annotations."
              }
            ],
            "displayName": "Predict Items",
            "displayIcon": "icon-dl-dell",
            "description": "Hosted chat completion API"
          },
          {
            "name": "predict_dataset",
            "input": [
              {
                "type": "Dataset",
                "name": "dataset",
                "description": "Dataloop Dataset Entity"
              },
              {
                "type": "Json",
                "name": "filters",
                "description": "Dataloop Filter DQL"
              }
            ],
            "output": [],
            "displayName": "Predict Dataset",
            "displayIcon": "icon-dl-dell",
            "description": "Hosted Chat Completion Dataset"
          }
        ]
      }
    ],
    "models": [
      {
        "name": "hosted-chat-completion",
        "moduleName": "hosted-chat-completion-module",
        "scope": "project",
        "status": "pre-trained",
        "configuration": {
          "system_prompt": "You are a helpful assistant. Give relevant and short answers, if you dont know the answer just say it, dont make up an answer",
          "model_name": "phi4-mini:latest",
          "app_id": "",
          "stream": true,
          "max_tokens": 4096,
          "temperature": 1.0,
          "top_p": 1.0
        },
        "description": "Chat completion via Dataloop-hosted service"
      }
    ]
  }
}
